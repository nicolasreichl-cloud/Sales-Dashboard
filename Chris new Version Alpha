            {["all", "high", "medium"].map((r) => (
              <button key={r} onClick={() => setFilterRelevance(r)} style={{
                padding: "5px 12px", borderRadius: 6, border: "1px solid",
                borderColor: filterRelevance === r ? "#6366F1" : "#1E293B",
