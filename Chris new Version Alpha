function LoadingState({ message = "Lade Daten..." }) {
  return (
    <div style={{ textAlign: "center", padding: "60px 0", color: "#475569" }}>
      <Loader size={28} color="#6366F1" style={{ animation: "spin 1s linear infinite", marginBottom: 12 }} />
      <div style={{ fontSize: 13 }}>{message}</div>
    </div>
  );
}

function ErrorState({ message, onRetry }) {
  return (
    <div style={{
      background: "#EF444415", border: "1px solid #EF444430",
      borderRadius: 10, padding: "20px 24px",
      display: "flex", alignItems: "flex-start", gap: 12,
    }}>
      <AlertCircle size={20} color="#EF4444" style={{ flexShrink: 0, marginTop: 1 }} />
      <div style={{ flex: 1 }}>
        <div style={{ color: "#EF4444", fontWeight: 600, fontSize: 14, marginBottom: 4 }}>
          HubSpot Verbindungsfehler
        </div>
        <div style={{ color: "#94A3B8", fontSize: 13, marginBottom: 10, fontFamily: "monospace" }}>
          {message}
        </div>
        <div style={{ color: "#64748B", fontSize: 12, marginBottom: 12 }}>
          Mögliche Ursachen: Token fehlt / abgelaufen · CORS-Proxy nicht aktiv · Netzwerkfehler
        </div>
        {onRetry && (
          <button onClick={onRetry} style={{
            padding: "6px 14px", borderRadius: 6, border: "1px solid #334155",
            background: "#1E293B", color: "#94A3B8", fontSize: 12, cursor: "pointer",
          }}>
            Erneut versuchen
          </button>
        )}
      </div>
    </div>
  );
