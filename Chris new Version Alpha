function getDaysSilent(lastContact) {
  if (!lastContact) return 9999;
  return Math.floor((new Date() - new Date(lastContact)) / (1000 * 60 * 60 * 24));
}

function getUrgency(deal) {
  const days = getDaysSilent(deal.lastContact);
  if (!deal.lastContact) return "never";
  if (days > 180) return "critical";
  if (days > 90)  return "high";
  if (days > 30)  return "medium";
  return "low";
}

const URGENCY_CONFIG = {
  critical: { label: "🔴 Kritisch",  color: "#EF4444", bg: "#EF444420" },
  high:     { label: "🟠 Hoch",      color: "#F97316", bg: "#F9731620" },
  medium:   { label: "🟡 Mittel",    color: "#EAB308", bg: "#EAB30820" },
  low:      { label: "🟢 Aktuell",   color: "#22C55E", bg: "#22C55E20" },
  never:    { label: "⚫ Nie",        color: "#94A3B8", bg: "#94A3B820" },
};

