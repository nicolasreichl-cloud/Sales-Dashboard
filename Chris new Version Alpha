function TriggerOutreachPage({ data }) {
  const [signals, setSignals] = useState(data.triggerSignals);
  const [activeSignal, setActiveSignal] = useState(null);
  const [generatingId, setGeneratingId] = useState(null);
  const [filterType, setFilterType] = useState("all");
  const [filterRelevance, setFilterRelevance] = useState("all");
  const [activeTab, setActiveTab] = useState("signals");

  const generateMessage = (signalId) => {
    setGeneratingId(signalId);
    setTimeout(() => {
      setSignals((prev) => prev.map((s) => {
        if (s.id !== signalId) return s;
        return {
          ...s, drafted: true,
          draftMessage: `Hallo ${s.contact.split(" ")[0]},\n\nich habe Ihren Beitrag zu "${s.signal.substring(0, 55)}..." gesehen – sehr spannend!\n\nGenau in diesem Bereich können wir bei ${s.company} einen echten Mehrwert schaffen. Unsere Plattform hilft dabei, die Integration effizienter und skalierbarer zu gestalten.\n\nWäre ein kurzes 15-minütiges Gespräch diese Woche möglich?\n\nBeste Grüße`,
        };
      }));
      setGeneratingId(null);
      setActiveSignal(signalId);
    }, 1800);
  };

  const filteredSignals = signals.filter((s) => {
    if (filterType !== "all" && s.type !== filterType) return false;
