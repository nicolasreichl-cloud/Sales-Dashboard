            : "Follow-up planen";
          return (
            <div key={deal.id} style={{
              padding: "12px 20px",
              borderBottom: i < filtered.length - 1 ? "1px solid #1A2740" : "none",
              display: "grid", gridTemplateColumns: "1fr 110px 120px 80px 80px 80px 140px",
