// EU MARKET COVERAGE PAGE
// ═══════════════════════════════════════════════════════════════

function EUMarketCoveragePage() {
  const [countryFilter, setCountryFilter] = useState("all");
  const [statusFilter, setStatusFilter] = useState("all");

  const countries = useMemo(() => {
    const map = {};
    ALL_UTILITIES.forEach(u => {
      if (!map[u.country]) map[u.country] = { total: 0, inHubspot: 0, contacted: 0, untouched: 0 };
      map[u.country].total++;
      if (u.inHubspot) map[u.country].inHubspot++;
      if (u.contacted) map[u.country].contacted++;
      if (!u.contacted) map[u.country].untouched++;
    });
    return Object.entries(map).sort((a, b) => b[1].total - a[1].total);
  }, []);

  const totals = useMemo(() => ({
    total:     ALL_UTILITIES.length,
    inHubspot: ALL_UTILITIES.filter(u => u.inHubspot).length,
    contacted: ALL_UTILITIES.filter(u => u.contacted).length,
    untouched: ALL_UTILITIES.filter(u => !u.contacted).length,
  }), []);

  const filtered = ALL_UTILITIES.filter(u => {
    if (countryFilter !== "all" && u.country !== countryFilter) return false;
    if (statusFilter === "untouched" && u.contacted) return false;
    if (statusFilter === "contacted" && !u.contacted) return false;
    if (statusFilter === "no_hubspot" && u.inHubspot) return false;
    return true;
  });

  const allCountries = [...new Set(ALL_UTILITIES.map(u => u.country))].sort();

  return (
    <div>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 24 }}>
        <div>
          <h2 style={{ color: "#F1F5F9", fontSize: 22, fontWeight: 700, marginBottom: 4 }}>EU Market Coverage</h2>
          <p style={{ color: "#64748B", fontSize: 13 }}>Europäische B2C Utilities · Top 120 Liste + Research · {ALL_UTILITIES.length} Unternehmen tracked</p>
        </div>
      </div>

      {/* Summary Cards */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 14, marginBottom: 28 }}>
        {[
          { label: "B2C Utilities tracked",  value: totals.total,     color: "#6366F1", sub: "Alle Länder" },
          { label: "In HubSpot",             value: totals.inHubspot, color: "#10B981", sub: "Im CRM erfasst" },
          { label: "Kontaktiert",            value: totals.contacted, color: "#3B82F6", sub: "Mind. 1 Outreach" },
          { label: "Whitespace",             value: totals.untouched, color: "#EF4444", sub: "Noch nicht kontaktiert" },
        ].map(s => (
          <div key={s.label} style={{
            background: "#1E293B", borderRadius: 12, padding: "18px 20px",
            borderLeft: `3px solid ${s.color}`,
          }}>
            <div style={{ color: "#94A3B8", fontSize: 12, marginBottom: 8 }}>{s.label}</div>
            <div style={{ color: "#F1F5F9", fontSize: 30, fontWeight: 700 }}>{s.value}</div>
            <div style={{ color: "#475569", fontSize: 11, marginTop: 4 }}>{s.sub}</div>
          </div>
        ))}
      </div>

      {/* Country Grid */}
      <SectionTitle><Globe size={14} color="#10B981" /> Coverage nach Land</SectionTitle>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(180px, 1fr))", gap: 10, marginBottom: 28 }}>
        {countries.map(([country, stats]) => {
          const pct = Math.round(stats.contacted / stats.total * 100);
          return (
            <div key={country}
              onClick={() => setCountryFilter(countryFilter === country ? "all" : country)}
              style={{
                background: countryFilter === country ? "#243044" : "#1E293B",
                border: `1px solid ${countryFilter === country ? "#6366F1" : "#243044"}`,
                borderRadius: 10, padding: "14px 16px", cursor: "pointer",
                transition: "all 0.15s",
              }}
              onMouseEnter={(e) => { if (countryFilter !== country) e.currentTarget.style.borderColor = "#6366F150"; }}
              onMouseLeave={(e) => { if (countryFilter !== country) e.currentTarget.style.borderColor = "#243044"; }}
            >
              <div style={{ color: "#F1F5F9", fontWeight: 600, fontSize: 13, marginBottom: 6 }}>{country}</div>
              <div style={{ display: "flex", gap: 10, fontSize: 12, color: "#64748B", marginBottom: 8 }}>
                <span><span style={{ color: "#F1F5F9", fontWeight: 600 }}>{stats.contacted}</span>/{stats.total} kontaktiert</span>
              </div>
              <div style={{ height: 4, borderRadius: 2, background: "#334155", overflow: "hidden" }}>
                <div style={{
                  width: `${pct}%`, height: "100%", borderRadius: 2,
                  background: pct >= 70 ? "#10B981" : pct >= 40 ? "#F59E0B" : "#6366F1",
                }} />
              </div>
              <div style={{ color: "#475569", fontSize: 11, marginTop: 4 }}>{pct}% Abdeckung</div>
            </div>
          );
        })}
      </div>

      {/* Utilities Table */}
      <SectionTitle><AlertTriangle size={14} color="#EF4444" /> Utility Details</SectionTitle>
      <div style={{ display: "flex", gap: 8, marginBottom: 14, flexWrap: "wrap", alignItems: "center" }}>
        <Filter size={14} color="#475569" />
        <select value={countryFilter} onChange={e => setCountryFilter(e.target.value)} style={{
          padding: "6px 12px", borderRadius: 8, border: "1px solid #334155",
          background: "#1E293B", color: "#94A3B8", fontSize: 12, cursor: "pointer",
        }}>
          <option value="all">Alle Länder</option>
          {allCountries.map(c => <option key={c} value={c}>{c}</option>)}
        </select>
        {[
          { value: "all",        label: "Alle" },
          { value: "untouched",  label: "⚪ Whitespace" },
          { value: "contacted",  label: "✓ Kontaktiert" },
          { value: "no_hubspot", label: "Nicht in HubSpot" },
        ].map(f => (
          <button key={f.value} onClick={() => setStatusFilter(f.value)} style={{
            padding: "5px 12px", borderRadius: 6, border: "1px solid",
            borderColor: statusFilter === f.value ? "#6366F1" : "#334155",
            background: statusFilter === f.value ? "#6366F120" : "#1E293B",
            color: statusFilter === f.value ? "#A5B4FC" : "#64748B",
            fontSize: 12, cursor: "pointer",
          }}>{f.label}</button>
        ))}
        <span style={{ color: "#475569", fontSize: 12, marginLeft: "auto" }}>{filtered.length} Utilities</span>
      </div>

      <div style={{ background: "#1E293B", borderRadius: 12, overflow: "hidden", border: "1px solid #243044" }}>
        <div style={{
          padding: "10px 20px", borderBottom: "1px solid #243044",
          display: "grid", gridTemplateColumns: "1fr 140px 100px 100px 120px", gap: 12,
        }}>
          {["Utility", "Land", "Quelle", "HubSpot", "Status"].map(h => (
            <span key={h} style={{ color: "#475569", fontSize: 11, fontWeight: 600, letterSpacing: "0.04em" }}>{h}</span>
          ))}
        </div>
        {filtered.length === 0 ? (
          <div style={{ padding: "32px 20px", textAlign: "center", color: "#475569", fontSize: 13 }}>Keine Utilities gefunden</div>
        ) : filtered.map((u, i) => (
          <div key={`${u.name}-${i}`} style={{
            padding: "10px 20px",
            borderBottom: i < filtered.length - 1 ? "1px solid #1A2740" : "none",
            display: "grid", gridTemplateColumns: "1fr 140px 100px 100px 120px",
            gap: 12, alignItems: "center",
          }}
            onMouseEnter={(e) => e.currentTarget.style.background = "#243044"}
            onMouseLeave={(e) => e.currentTarget.style.background = "transparent"}
          >
            <span style={{ color: "#F1F5F9", fontSize: 13 }}>{u.name}</span>
            <span style={{ color: "#64748B", fontSize: 12 }}>{u.country}</span>
            <span style={{
              fontSize: 11, padding: "2px 8px", borderRadius: 4, fontWeight: 600,
              background: u.source === "Top 120" ? "#6366F120" : "#334155",
              color: u.source === "Top 120" ? "#A5B4FC" : "#94A3B8",
            }}>{u.source}</span>
            <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
              <div style={{
                width: 8, height: 8, borderRadius: "50%",
                background: u.inHubspot ? "#10B981" : "#475569",
              }} />
              <span style={{ color: u.inHubspot ? "#10B981" : "#475569", fontSize: 12 }}>
                {u.inHubspot ? "Ja" : "Nein"}
              </span>
            </div>
            <span style={{
              fontSize: 11, padding: "3px 10px", borderRadius: 4, fontWeight: 600,
              background: u.contacted ? "#10B98120" : "#EF444415",
              color: u.contacted ? "#10B981" : "#EF4444",
            }}>{u.contacted ? "Kontaktiert" : "Whitespace"}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

