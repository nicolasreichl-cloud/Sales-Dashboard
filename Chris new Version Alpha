                        <CheckCircle size={14} color="#10B981" />
                        <span style={{ color: "#10B981", fontSize: 12, fontWeight: 600 }}>KI-Nachrichtenentwurf</span>
                        <span style={{ color: "#475569", fontSize: 11 }}>· Bereit zur Überprüfung</span>
                      </div>
                      <textarea defaultValue={signal.draftMessage} rows={8} style={{
